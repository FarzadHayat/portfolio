---
// PetGhost — friendly Casper-style pet for the portfolio
// Desktop only (hidden lg:flex). No props, no dependencies.
---

<div
  id="pet-ghost"
  class="fixed bottom-6 left-6 z-50 hidden lg:block"
>
  <div
    id="ghost-bubble"
    class="ghost-bubble pointer-events-none"
    aria-live="polite"
  >
    Welcome, mortal 👻
  </div>
  <button id="ghost-emoji" type="button" class="ghost-emoji cursor-pointer select-none" aria-label="Pet ghost">
    👻
  </button>
</div>

<style>
  /* ── Layout ─────────────────────────────────────────── */
  .ghost-emoji {
    font-size: 2.5rem;
    line-height: 1;
    display: block;
    /* reset button styles */
    background: none;
    border: none;
    padding: 0;
    animation: ghost-float 3s ease-in-out infinite;
    transition: filter 0.2s ease;
  }

  .ghost-emoji:hover {
    filter: drop-shadow(0 0 8px rgba(167, 139, 250, 0.6));
  }

  /* ── Speech bubble ──────────────────────────────────── */
  .ghost-bubble {
    background: white;
    color: #1a1a2e;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 999px;
    white-space: nowrap;
    max-width: calc(100vw - 3rem);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
    /*
     * Fixed to the viewport — same left anchor as the ghost (left-6 = 1.5rem),
     * tall enough above so the tail never touches the emoji.
     * bottom = ghost-bottom(1.5rem) + emoji-height(2.5rem) + gap(1.5rem) = 5.5rem
     */
    position: fixed;
    bottom: 5.5rem;
    left: 2rem;
    transform: translateY(-4px);
    opacity: 0;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  /* downward tail — points at the ghost emoji center (half of 2.5rem font-size) */
  .ghost-bubble::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 1.25rem;
    transform: translateX(-50%);
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 6px solid white;
  }

  .ghost-bubble.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Animations ─────────────────────────────────────── */
  @keyframes ghost-float {
    0%, 100% { transform: translateY(0px) rotate(-3deg); }
    50%       { transform: translateY(-10px) rotate(3deg); }
  }

  @keyframes ghost-bounce {
    0%   { transform: scale(1) rotate(0deg); }
    30%  { transform: scale(1.4) rotate(-10deg); }
    60%  { transform: scale(0.9) rotate(5deg); }
    100% { transform: scale(1) rotate(0deg); }
  }

  .ghost-emoji.bouncing {
    animation: ghost-bounce 0.4s ease forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .ghost-emoji,
    .ghost-emoji.bouncing {
      animation: none;
    }
    .ghost-bubble {
      transition: none;
      transform: none !important;
    }
  }
</style>

<script>
  // ── Section quips ──────────────────────────────────────
  // Inactive sections are included for when they get re-enabled.
  const SECTION_QUIPS: Record<string, string> = {
    hero:           'Welcome, mortal 👻',
    projects:       'These projects are to die for 💀',
    work:           'Impressive résumé for a living person',
    education:      'Still smarter than me 🎓',
    certifications: 'Certified haunted engineer 🏅',
    hackathons:     'Hacking the afterlife since forever',
    spotify:        'This human has great taste in music 🎵',
    about:          'A human with good taste!',
    blog:           'Wise words from beyond the grave 📖',
    // Note: Contact component renders a <footer>, not <section id="contact">.
    // Add id="contact" to Contact.astro's root element when re-enabling this section.
    contact:        'Go on... say hello 👋',
  };

  const CLICK_MESSAGES = [
    'Boo! 👀',
    'You found me!',
    'Pet accepted ✅',
    'Hehe 👻',
    "Stop that... actually don't",
  ];

  let bubbleTimer: ReturnType<typeof setTimeout> | null = null;
  let clickCooldown = false;
  let currentObserver: IntersectionObserver | null = null;

  // ── Bubble helpers ─────────────────────────────────────
  function showBubble(bubble: HTMLElement, text: string, durationMs = 4000) {
    if (bubbleTimer) clearTimeout(bubbleTimer);
    bubble.textContent = text;
    bubble.classList.add('visible');
    bubbleTimer = setTimeout(() => bubble.classList.remove('visible'), durationMs);
  }

  // ── Per-page init — re-queries DOM so refs are never stale after View Transitions ──
  function init() {
    const bubble = document.getElementById('ghost-bubble') as HTMLElement | null;
    const emoji  = document.getElementById('ghost-emoji')  as HTMLElement | null;
    if (!bubble || !emoji) return;

    // ── Section observer ─────────────────────────────────
    if (currentObserver) currentObserver.disconnect();

    const heroEl = document.querySelector('section.hero');
    const namedEls = Object.keys(SECTION_QUIPS)
      .filter((k) => k !== 'hero')
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    const targets: Array<{ el: Element; quip: string }> = [];
    if (heroEl) targets.push({ el: heroEl, quip: SECTION_QUIPS.hero });
    namedEls.forEach((el) => targets.push({ el, quip: SECTION_QUIPS[el.id] }));

    currentObserver = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const target = targets.find((t) => t.el === entry.target);
          if (target) showBubble(bubble, target.quip);
          obs.unobserve(entry.target); // fire once per section per page load
        });
      },
      { threshold: 0.3 }
    );
    targets.forEach(({ el }) => currentObserver!.observe(el));

    // ── Click handler ────────────────────────────────────
    // Fresh element on each navigation — no duplicate listener risk.
    emoji.addEventListener('click', () => {
      if (clickCooldown) return;
      clickCooldown = true;

      const msg = CLICK_MESSAGES[Math.floor(Math.random() * CLICK_MESSAGES.length)];
      showBubble(bubble, msg, 2000);

      emoji.classList.remove('bouncing');
      void emoji.offsetWidth; // force reflow to restart animation
      emoji.classList.add('bouncing');

      setTimeout(() => {
        emoji.classList.remove('bouncing');
        clickCooldown = false;
      }, 2000);
    });
  }

  // ── Init ───────────────────────────────────────────────
  // Safe to add once: Astro bundles and deduplicates <script> modules,
  // so this runs only once per page lifetime regardless of View Transitions.
  document.addEventListener('astro:page-load', init);
</script>
